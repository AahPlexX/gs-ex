{
  "manifest_version": 3,
  "name": "Genspark Exporter",
  "description": "Exports the active Genspark artifact as JSON, Markdown, standalone HTML, or a complete bundle.",
  "version": "0.3.0",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Export this Genspark artifact",
    "default_popup": "popup.html"
  }
}
